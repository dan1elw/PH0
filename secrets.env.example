# Pi-hole Image – Secrets Konfiguration
# ========================================
# Diese Datei NIEMALS ins Git-Repository committen!
# Kopiere diese Datei nach secrets.env und fülle die Werte aus:
#   cp secrets.env.example secrets.env
#
# Die Datei wird beim Flash-Vorgang auf die Boot-Partition kopiert
# und beim ersten Boot vom First-Boot-Service eingelesen und gelöscht.

# Pi-hole Admin-Passwort (für Web UI unter /admin)
PIHOLE_PASSWORD=

# WLAN-Konfiguration
WIFI_SSID=
WIFI_PASSWORD=
WIFI_COUNTRY=DE

# SSH Public Key (der komplette Key, z.B. ssh-ed25519 AAAA... user@host)
SSH_PUBLIC_KEY=

# Hostname (optional, Standard: pihole)
PI_HOSTNAME=pihole
