# Pi-hole Image – Secrets Konfiguration
# ========================================
# Kopiere diese Datei nach secrets.env und fülle die Werte aus:
#   cp secrets.env.example secrets.env
#
# Die "secrets.env" Datei ist in .gitignore gelistet und wird nicht
# aufs GitHub Repository veröffentlicht.
#
# Die Datei wird beim Flash-Vorgang auf die Boot-Partition kopiert
# und beim ersten Boot vom First-Boot-Service eingelesen und gelöscht.
#
# WICHTIG: Alle Werte MÜSSEN in doppelten Anführungszeichen stehen!
#          Besonders bei Leerzeichen oder Sonderzeichen (z.B. WLAN-Name,
#          SSH-Key) führt das Weglassen zu Fehlern beim First Boot.

# ============================================================
# Benutzer
# ============================================================
# Linux-Benutzername für SSH-Login und sudo
PI_USER="pi"

# Benutzer-Passwort (für sudo und Console-Login als Fallback)
# SSH nutzt ausschließlich Key-Authentifizierung, aber das Passwort
# wird benötigt für: sudo, lokalen Console-Login (Monitor + Tastatur),
# und als Notfall-Zugang falls der SSH-Key nicht funktioniert.
PI_USER_PASSWORD=""

# ============================================================
# Pi-hole
# ============================================================
# Admin-Passwort für die Pi-hole Web UI (/admin)
PIHOLE_PASSWORD=""

# ============================================================
# WLAN
# ============================================================
WIFI_SSID=""
WIFI_PASSWORD=""
WIFI_COUNTRY="DE"

# ============================================================
# SSH
# ============================================================
# Öffentlicher SSH-Schlüssel (der komplette Key)
# Beispiel: ssh-ed25519 AAAA...rest-des-keys... user@host
# Tipp: cat ~/.ssh/id_ed25519.pub
SSH_PUBLIC_KEY=""

# ============================================================
# System (optional)
# ============================================================
# Hostname (Standard: pihole)
PI_HOSTNAME="pihole"

# Statische IP-Adresse (Standard: 192.168.178.49)
PI_IP="192.168.178.49"

# Gateway / Router IP (Standard: 192.168.178.1)
PI_GATEWAY="192.168.178.1"

# Subnetz-Präfixlänge (Standard: 24)
PI_PREFIX="24"
